---
import BaseLayout from "../layouts/BaseLayout.astro";

const brandedIdWithout = `type UserId = string;
type ProductId = string;

function assignToUser(id: UserId) { ... }
function getProduct(id: ProductId) { ... }

assignToUser(productId); // compiles. runtime bug.
getProduct(userId);      // compiles. another bug.`;

const brandedIdWith = `import { createBrandedId } from '@sotajs/ddd';

const UserId = createBrandedId({
  brand: 'UserId',
  schema: z.string().uuid(),
});
const ProductId = createBrandedId({
  brand: 'ProductId',
  schema: z.string().uuid(),
});

assignToUser(productId); // TypeScript error
getProduct(userId);      // TypeScript error`;

const encapsWithout = `class User {
  constructor(public bio: string) {}
}
const user = new User('hello');

user.bio = 'anything'; // direct mutation

// ORM saves it. Invariant check? Skipped.
// JSON.stringify(user) — full access.
// Six months later: who changed this?`;

const encapsWith = `const User = createEntity({
  schema: UserSchema,
  actions: {
    updateBio(state, bio) {
      state.bio = bio;
    },
  },
});

user.actions.updateBio('new bio');  // ✓
user.props.bio = 'x'; // TypeError!
user.props.items.push(...);     // TypeError!`;

const manualClass = `class User {
  private bio: string;
  private username: string;

  constructor(props: UserProps) {
    this.bio  = props.bio;
    this.username = props.username;
  }

  updateBio(bio: string) {
    if (bio.length > 500)
      throw new Error("Too long");
    this.bio = bio;
  }
  updateUsername(name: string) {
    if (!name) throw new Error();
    this.username = name;
  }
  setBio(v) { this.bio = v; }
  setUsername(v) { this.username = v; }
  get props() {
    return Object.freeze({...this});
  }
  equals(o) {
    return this.id === o.id;
  }
  // ×20 entities = 900 lines
  // Nobody writes this.
  // They write: interface User {}
}`;

const configEntity = `const User = createEntity({
  schema: UserSchema,
  actions: {
    updateBio(state, bio) {
      state.bio = bio;
    },
    updateUsername(state, n) {
      state.username = n;
    },
  },
  computed: {
    displayName(props) {
      return props.username;
    },
  },
});
// deepFreeze — automatic
// equals() — automatic
// auto-setters — automatic
// type inference — automatic`;

const invariantsWithout = `// OrderService.ts
async addItem(orderId, item) {
  const order = await db.orders.find(orderId);
  // Did we check invariants? Maybe.
  // Is this check in every service
  // that mutates Order? Probably not.
  order.items.push(item);
}

// CheckoutService.ts — different file
// Same invariant? Different?
// Six months: total ≠ sum(items)`;

const invariantsWith = `const Order = createAggregate({
  schema: OrderSchema,
  invariants: [
    (props) => {
      if (props.items.length === 0)
        throw new Error(
          'Must have ≥ 1 item'
        );
    },
  ],
  actions: {
    addItem(state, item) {
      state.items.push(item);
    },
  },
});
// Invariants run on .create()
// AND after every action.
// Cannot forget. Cannot skip.`;

const fullEntity = `import { z } from 'zod';
import { createEntity } from '@sotajs/ddd';

const UserProfileSchema = z.object({
  id: z.string().uuid(),
  username: z.string(),
  bio: z.string().optional(),
});
type UserProfileProps =
  z.infer<typeof UserProfileSchema>;

export const UserProfile = createEntity({
  schema: UserProfileSchema,
  actions: {
    updateUsername(state, name) {
      state.username = name;
    },
    updateBio(state, bio) {
      state.bio = bio;
    },
  },
  computed: {
    displayName(props) {
      return props.username;
    },
  },
});
export type UserProfile =
  ReturnType<typeof UserProfile.create>;`;

const useCase = `// Schema validates on create
const profile = UserProfile.create({
  id: 'b3f1ae2c-abcd',
  username: 'alice',
});

export const updateProfile = async (
  userId: string, bio: string,
) => {
  const profile = await profiles
    .findById(userId);

  profile.actions.updateBio(bio);
  await profiles.save(profile);

  return {
    id: profile.id,
    displayName: profile.displayName,
  };
};`;

const pushEscape = `user.props.items.push(...);`;
---

<BaseLayout title="sotajs/ddd" description="Tactical DDD for Node.js / TypeScript — four functions, zero lock-in.">

<style>
  h1 { font-size: 2.8rem; font-weight: 700; line-height: 1.08; letter-spacing: -0.03em; margin-bottom: 16px; }
  h2 { font-size: 1.45rem; font-weight: 600; margin-bottom: 12px; }
  .sub { color: var(--color-text-secondary); font-size: 1.05rem; line-height: 1.65; max-width: 600px; }
  .label { font-family: var(--font-mono); font-size: 0.7rem; text-transform: uppercase; letter-spacing: 0.12em; color: var(--color-text-muted); margin-bottom: 12px; }
  .row { display: flex; gap: 48px; align-items: flex-start; }
  .col { flex: 1; min-width: 0; }

  .chrome { border: 1px solid var(--color-border-default); border-radius: 8px; overflow: hidden; background: var(--color-bg-code); }
  .chrome-bar { display: flex; align-items: center; gap: 8px; padding: 10px 16px; border-bottom: 1px solid var(--color-border-muted); background: var(--color-bg-surface); }
  .chrome-dot { width: 12px; height: 12px; border-radius: 50%; }
  .chrome-dot.r { background: var(--color-red); opacity: 0.6; }
  .chrome-dot.y { background: var(--color-amber); opacity: 0.6; }
  .chrome-dot.g { background: var(--color-green); opacity: 0.6; }
  .chrome-fname { margin-left: 8px; font-size: 0.75rem; color: var(--color-text-muted); font-family: var(--font-mono); }
  .chrome pre { border: none; border-radius: 0; margin: 0; }

  .gap-header { display: flex; align-items: baseline; gap: 16px; margin-bottom: 16px; }
  .gap-num { font-family: var(--font-mono); font-size: 0.8rem; color: var(--color-accent); min-width: 28px; }
  .gap-problem { font-family: var(--font-mono); font-size: 0.72rem; color: var(--color-red); background: rgba(248,81,73,0.08); padding: 2px 8px; border-radius: 3px; margin-bottom: 12px; display: inline-block; }

  .contrast { display: grid; grid-template-columns: 1fr 1fr; gap: 24px; }
  .contrast-col { position: relative; }
  .contrast-label { position: absolute; top: -28px; right: 0; font-family: var(--font-mono); font-size: 0.65rem; padding: 2px 8px; border-radius: 3px; }
  .contrast-label.bad { background: rgba(248,81,73,0.15); color: var(--color-red); }
  .contrast-label.good { background: rgba(34,211,238,0.12); color: var(--color-accent); }

  .result { display: flex; gap: 32px; margin-top: 24px; }
  .result-item { flex: 1; background: var(--color-bg-surface); border: 1px solid var(--color-border-muted); border-radius: 6px; padding: 16px; }
  .result-item h4 { font-size: 0.88rem; font-weight: 600; margin-bottom: 6px; }
  .result-item p { color: var(--color-text-secondary); font-size: 0.82rem; line-height: 1.5; }

  .cta-block { text-align: center; padding: 100px 0 80px; }
  .cta-block pre { display: inline-block; text-align: left; margin-bottom: 16px; }
  .small-label { font-size: 0.7rem; color: var(--color-text-muted); font-family: var(--font-mono); text-transform: uppercase; letter-spacing: 0.1em; margin-bottom: 8px; }

  @media (max-width: 768px) {
    h1 { font-size: 1.7rem; }
    .row, .result { flex-direction: column; gap: 24px; }
    .contrast { grid-template-columns: 1fr; }
  }
</style>

<!-- ═══════════ HERO ═══════════ -->
<section class="max-w-[960px] mx-auto px-6 pt-24 pb-16 sm:pt-32 sm:pb-18">
  <p class="label">@sotajs/ddd</p>
  <h1>Tactical DDD was designed for<br/>a runtime <span style="color: var(--color-accent);">Node doesn't provide</span></h1>
  <p class="sub">
    Nominal typing, real encapsulation, rich domain models — DDD patterns assume a Java/C# runtime.
    In Node you pay for every invariant with manual infrastructure. Most teams cut corners,
    keeping the vocabulary and losing the guarantees.
  </p>
  <p class="sub" style="margin-top: 12px; color: var(--color-accent); font-weight: 500;">
    Four functions. Zero lock-in. DDD without the infrastructure tax.
  </p>
</section>

<!-- ═══════════ GAP 1: BRANDED ID ═══════════ -->
<section class="max-w-[960px] mx-auto px-6 py-16 sm:py-20 border-t border-border-muted">
  <div class="gap-header">
    <span class="gap-num">01</span>
    <h2>Structural typing: <span style="font-weight: 400;">two strings, same type</span></h2>
  </div>
  <span class="gap-problem">TS lets you pass a UserId where a ProductId is expected</span>

  <div class="row" style="margin-top: 20px;">
    <div class="col">
      <div class="chrome">
        <div class="chrome-bar"><span class="chrome-dot r"></span><span class="chrome-dot y"></span><span class="chrome-dot g"></span><span class="chrome-fname">without library</span></div>
        <pre class="!border-0 !rounded-none !m-0 !p-5 text-sm"><code>{brandedIdWithout}</code></pre>
      </div>
    </div>
    <div class="col">
      <div class="chrome">
        <div class="chrome-bar"><span class="chrome-dot r"></span><span class="chrome-dot y"></span><span class="chrome-dot g"></span><span class="chrome-fname">with @sotajs/ddd</span></div>
        <pre class="!border-0 !rounded-none !m-0 !p-5 text-sm"><code>{brandedIdWith}</code></pre>
      </div>
    </div>
  </div>
  <div class="result">
    <div class="result-item">
      <h4>Compile-time safety</h4>
      <p><code>UserId</code> and <code>ProductId</code> are distinct types. The compiler catches swaps before they reach production.</p>
    </div>
    <div class="result-item">
      <h4>Validation on creation</h4>
      <p>Schema validates the raw string on <code>.create()</code>. UUID format enforced, no silent garbage.</p>
    </div>
    <div class="result-item">
      <h4>JSON-safe</h4>
      <p><code>.toJSON()</code> and <code>.toString()</code> built in. Serializes to plain string, deserializes through <code>.create()</code>.</p>
    </div>
  </div>
</section>

<!-- ═══════════ GAP 2: ENCAPSULATION ═══════════ -->
<section class="max-w-[960px] mx-auto px-6 py-16 sm:py-20 border-t border-border-muted">
  <div class="gap-header">
    <span class="gap-num">02</span>
    <h2>Encapsulation: <span style="font-weight: 400;">no true privacy in JS</span></h2>
  </div>
  <span class="gap-problem">Private fields exist but serialization strips them. ORMs write past every guard.</span>

  <div class="row" style="margin-top: 20px;">
    <div class="col">
      <div class="chrome" style="margin-bottom: 16px;">
        <div class="chrome-bar"><span class="chrome-dot r"></span><span class="chrome-dot y"></span><span class="chrome-dot g"></span><span class="chrome-fname">without library</span></div>
        <pre class="!border-0 !rounded-none !m-0 !p-5 text-sm"><code>{encapsWithout}</code></pre>
      </div>
    </div>
    <div class="col">
      <div class="chrome" style="margin-bottom: 16px;">
        <div class="chrome-bar"><span class="chrome-dot r"></span><span class="chrome-dot y"></span><span class="chrome-dot g"></span><span class="chrome-fname">with @sotajs/ddd</span></div>
        <pre class="!border-0 !rounded-none !m-0 !p-5 text-sm"><code>{encapsWith}</code></pre>
      </div>
    </div>
  </div>
  <div class="result">
    <div class="result-item">
      <h4>WeakMap state storage</h4>
      <p>State lives outside <code>this</code>. No public fields. No accidental exposure through iteration or logging.</p>
    </div>
    <div class="result-item">
      <h4>deepFreeze on every read</h4>
      <p><code>.props</code> returns a frozen snapshot. Mutation throws TypeError. Not a convention — a physical constraint.</p>
    </div>
    <div class="result-item">
      <h4>Actions — single path</h4>
      <p>Every state change has a name, a typed signature, and a single location. Grep <code>actions.updateBio</code> → you found every call site.</p>
    </div>
  </div>
</section>

<!-- ═══════════ GAP 3: COST ═══════════ -->
<section class="max-w-[960px] mx-auto px-6 py-16 sm:py-20 border-t border-border-muted">
  <div class="gap-header">
    <span class="gap-num">03</span>
    <h2>The cost gap: <span style="font-weight: 400;">rich model = 900 lines of boilerplate</span></h2>
  </div>
  <span class="gap-problem">Manual DDD is correct but nobody writes it. Anemic models win not by merit but by price.</span>

  <div class="contrast" style="margin-top: 20px;">
    <div class="contrast-col">
      <span class="contrast-label bad">Manual — 45 lines per entity, never written</span>
      <pre class="!border-0 !rounded-none !m-0 !p-5 text-sm"><code>{manualClass}</code></pre>
    </div>
    <div class="contrast-col">
      <span class="contrast-label good">@sotajs/ddd — 3 fields of config</span>
      <pre class="!border-0 !rounded-none !m-0 !p-5 text-sm"><code>{configEntity}</code></pre>
    </div>
  </div>
</section>

<!-- ═══════════ GAP 4: INVARIANTS ═══════════ -->
<section class="max-w-[960px] mx-auto px-6 py-16 sm:py-20 border-t border-border-muted">
  <div class="gap-header">
    <span class="gap-num">04</span>
    <h2>Culture: <span style="font-weight: 400;">invariants are optional by default</span></h2>
  </div>
  <span class="gap-problem">Node ecosystem thinks in data transformations. Invariants live in if-statements scattered across services.</span>

  <div class="row" style="margin-top: 20px;">
    <div class="col">
      <div class="chrome" style="margin-bottom: 16px;">
        <div class="chrome-bar"><span class="chrome-dot r"></span><span class="chrome-dot y"></span><span class="chrome-dot g"></span><span class="chrome-fname">without library — invariants are optional</span></div>
        <pre class="!border-0 !rounded-none !m-0 !p-5 text-sm"><code>{invariantsWithout}</code></pre>
      </div>
    </div>
    <div class="col">
      <div class="chrome" style="margin-bottom: 16px;">
        <div class="chrome-bar"><span class="chrome-dot r"></span><span class="chrome-dot y"></span><span class="chrome-dot g"></span><span class="chrome-fname">with @sotajs/ddd — required</span></div>
        <pre class="!border-0 !rounded-none !m-0 !p-5 text-sm"><code>{invariantsWith}</code></pre>
      </div>
    </div>
  </div>
  <div class="result">
    <div class="result-item">
      <h4>Required by TypeScript</h4>
      <p><code>invariants</code> is not optional on <code>createAggregate</code>. The config won't compile without it. You cannot accidentally ship an aggregate with no rules.</p>
    </div>
    <div class="result-item">
      <h4>Checked on every action</h4>
      <p>Invariants run at <code>.create()</code> and after every action. You don't "remember to call validate." The library does it.</p>
    </div>
    <div class="result-item">
      <h4>Single source of truth</h4>
      <p>Change one business rule → change it in one place. Every action and every create picks it up automatically.</p>
    </div>
  </div>
</section>

<!-- ═══════════ FULL EXAMPLE ═══════════ -->
<section class="max-w-[960px] mx-auto px-6 py-16 sm:py-20 border-t border-border-muted">
  <p class="label">The whole picture</p>
  <h2>One entity. From declaration to use case.</h2>
  <p class="sub" style="margin-bottom: 28px;">
    Your Zod schema. Your actions. Your computed properties. The library handles the rest.
  </p>

  <div class="row">
    <div class="col">
      <div class="small-label">Declaration</div>
      <div class="chrome" style="margin-bottom: 20px;">
        <div class="chrome-bar"><span class="chrome-dot r"></span><span class="chrome-dot y"></span><span class="chrome-dot g"></span><span class="chrome-fname">user-profile.entity.ts</span></div>
        <pre class="!border-0 !rounded-none !m-0 !p-5 text-sm"><code>{fullEntity}</code></pre>
      </div>
    </div>
    <div class="col">
      <div class="small-label">Usage in a command</div>
      <div class="chrome">
        <div class="chrome-bar"><span class="chrome-dot r"></span><span class="chrome-dot y"></span><span class="chrome-dot g"></span><span class="chrome-fname">update-profile.command.ts</span></div>
        <pre class="!border-0 !rounded-none !m-0 !p-5 text-sm"><code>{useCase}</code></pre>
      </div>
    </div>
  </div>
</section>

<!-- ═══════════ OBJECTIONS ═══════════ -->
<section class="max-w-[960px] mx-auto px-6 py-16 sm:py-20 border-t border-border-muted">
  <p class="label">Your stack</p>
  <h2>Four functions. Not a framework.</h2>
  <div class="result" style="margin-top: 20px;">
    <div class="result-item">
      <h4>Works inside NestJS — or anything</h4>
      <p>Your controllers, DI, and modules stay as they are. No decorators, no base classes, no new DI system.</p>
    </div>
    <div class="result-item">
      <h4>One module at a time</h4>
      <p>Replace <code>interface Order</code> with <code>createAggregate</code> in one service. The app doesn't notice. Try on Friday.</p>
    </div>
    <div class="result-item">
      <h4>No new vocabulary</h4>
      <p>You already write Zod schemas for DTOs. Actions are functions. Computed are getters. The library removes the boilerplate between them.</p>
    </div>
  </div>
</section>

<!-- ═══════════ CTA ═══════════ -->
<section class="max-w-[960px] mx-auto px-6 py-16 sm:py-20 border-t border-border-muted">
  <div class="cta-block">
    <pre class="inline-block bg-bg-code border border-border-default rounded-md px-5 py-3 font-mono text-sm mb-4"><code>npm install @sotajs/ddd</code></pre>
    <p class="text-text-muted text-sm">TypeScript ^5.0 · Zero dependencies · Works with Zod, ArkType, Valibot · <a href="https://github.com/kaizin-lab/sotajs-ddd" class="text-accent hover:underline">GitHub</a></p>
  </div>
</section>

</BaseLayout>
