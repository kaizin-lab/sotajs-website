---
import BaseLayout from "../layouts/BaseLayout.astro";

const entityCode = `import { z } from 'zod';
import { createEntity } from '@sotajs/ddd';

const UserProfileSchema = z.object({
  id: z.string().uuid(),
  username: z.string(),
  bio: z.string().optional(),
});
type UserProfileProps = z.infer<typeof UserProfileSchema>;

export const UserProfile = createEntity({
  schema: UserProfileSchema,
  actions: {
    updateUsername: (state, newUsername: string) => {
      state.username = newUsername;
    },
    updateBio: (state, bio: string) => {
      state.bio = bio;
    },
  },
  computed: {
    displayName: (props) => props.username,
  },
});
export type UserProfile = ReturnType<typeof UserProfile.create>;`;

const usageCode = `// Create from API input — schema validates + infers types
const profile = UserProfile.create({
  id: 'b3f1ae2c-abcd',
  username: 'alice',
});

// Use in a command
export const updateProfileCommand = async (
  userId: string,
  bio: string,
) => {
  const profile = await profiles.findById(userId);

  profile.actions.updateBio(bio);
  await profiles.save(profile);

  return {
    id: profile.id,
    displayName: profile.displayName,
  };
};`;
---

<BaseLayout title="sotajs/ddd" description="DDD without the dogma. Describe your domain, get a typed entity.">

<!-- ── HERO ──────────────────────────────────────────────── -->
<section class="max-w-[960px] mx-auto px-6 pt-24 pb-16 sm:pt-32 sm:pb-24">
  <div class="space-y-6 max-w-2xl">
    <p class="text-accent font-mono text-xs tracking-[0.15em] uppercase">Domain modeling library</p>
    <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold tracking-tight leading-[1.05]">
      You think DDD is hard.<br/>
      <span class="text-accent">It's no harder than your domain.</span>
    </h1>
    <p class="text-lg sm:text-xl text-text-secondary leading-relaxed max-w-lg">
      You already describe your data with Zod schemas.
      <code>@sotajs/ddd</code> takes the same schema and gives you
      an entity with typed actions, computed properties, and identity —
      no DDD book required.
    </p>
    <div class="flex flex-wrap gap-3 pt-2">
      <a href="/docs/getting-started/" class="inline-flex items-center gap-2 px-5 py-2.5 bg-accent text-bg-root font-semibold rounded-md text-sm hover:brightness-110 transition-all">
        Get Started
        <span class="font-mono">&rarr;</span>
      </a>
      <a href="https://github.com/kaizin-lab/sotajs-ddd" class="inline-flex items-center gap-2 px-5 py-2.5 border border-border-default text-text-primary font-medium rounded-md text-sm hover:border-text-muted transition-all">
        GitHub
      </a>
    </div>
  </div>
</section>

<!-- ── THESIS: THE MODEL IS YOUR SCHEMA ──────────────────── -->
<section class="border-y border-border-muted bg-bg-surface/50">
  <div class="max-w-[960px] mx-auto px-6 py-16 sm:py-20">
    <div class="max-w-lg mb-8">
      <p class="text-text-muted text-xs font-mono uppercase tracking-[0.15em] mb-3">The idea</p>
      <h2 class="text-2xl font-semibold mb-3">Your Zod schema <span class="text-accent">is</span> your domain model</h2>
      <p class="text-text-secondary leading-relaxed">
        No new DSL. No decorators. No annotations. The same schema you use for
        API validation defines your entity's shape, types, and runtime contract.
        <code>z.infer</code> gives you the props type. <code>ReturnType</code> gives you
        the entity instance type. Zero drift between validation and domain code.
      </p>
    </div>

    <div class="bg-bg-code border border-border-default rounded-lg overflow-hidden">
      <div class="flex items-center gap-2 px-4 py-2.5 border-b border-border-muted bg-bg-surface">
        <span class="w-3 h-3 rounded-full bg-red/60"></span>
        <span class="w-3 h-3 rounded-full bg-amber/60"></span>
        <span class="w-3 h-3 rounded-full bg-green/60"></span>
        <span class="ml-3 text-xs text-text-muted font-mono">user-profile.entity.ts</span>
      </div>
      <pre class="!border-0 !rounded-none !m-0 !p-5 text-sm language-typescript"><code>{entityCode}</code></pre>
    </div>
  </div>
</section>

<!-- ── ANATOMY ───────────────────────────────────────────── -->
<section class="max-w-[960px] mx-auto px-6 py-16 sm:py-20">
  <p class="text-text-muted text-xs font-mono uppercase tracking-[0.15em] mb-3">Engineering tour</p>
  <h2 class="text-2xl font-semibold mb-10">What <code class="text-[1.05em]">createEntity</code> actually gives you</h2>

  <div class="grid sm:grid-cols-2 gap-x-10 gap-y-8">
    <div>
      <p class="text-accent font-mono text-xs mb-1.5">01</p>
      <h3 class="text-base font-semibold text-text-primary mb-1.5 !mt-0">Actions — the only path to mutation</h3>
      <p class="text-text-secondary text-sm leading-relaxed">
        <code>entity.props</code> returns a frozen snapshot. You cannot do
        <code>entity.props.username = "x"</code>. State changes only through
        explicitly defined actions. Every mutation has a name, a typed signature,
        and a single place to find it.
      </p>
    </div>

    <div>
      <p class="text-accent font-mono text-xs mb-1.5">02</p>
      <h3 class="text-base font-semibold text-text-primary mb-1.5 !mt-0">Computed — derived state as a property</h3>
      <p class="text-text-secondary text-sm leading-relaxed">
        <code>profile.displayName</code> is a property, not a function call.
        Defined once in config, reads like native data, derives from current state.
        No caching to manage, no recalculation to trigger.
      </p>
    </div>

    <div>
      <p class="text-accent font-mono text-xs mb-1.5">03</p>
      <h3 class="text-base font-semibold text-text-primary mb-1.5 !mt-0">Auto-setters for every schema field</h3>
      <p class="text-text-secondary text-sm leading-relaxed">
        Every field in your schema (except <code>id</code>) gets a
        <code>setField(value)</code> method. No code generation step —
        the library introspects your Zod schema's <code>.shape</code> at definition time
        and builds setters automatically.
      </p>
    </div>

    <div>
      <p class="text-accent font-mono text-xs mb-1.5">04</p>
      <h3 class="text-base font-semibold text-text-primary mb-1.5 !mt-0">Identity — equality by id</h3>
      <p class="text-text-secondary text-sm leading-relaxed">
        <code>entity.equals(other)</code> compares by <code>id</code>, not object
        reference. Two instances loaded from different queries — same id, same entity.
        Critical for collections, deduplication, and caching.
      </p>
    </div>

    <div>
      <p class="text-accent font-mono text-xs mb-1.5">05</p>
      <h3 class="text-base font-semibold text-text-primary mb-1.5 !mt-0">Validator-agnostic</h3>
      <p class="text-text-secondary text-sm leading-relaxed">
        <code>schema</code> accepts Zod or Valibot (<code>.parse()</code> interface).
        <code>type</code> accepts ArkType (fastest validation path).
        <code>validate</code> accepts any <code>(data: unknown) =&gt; T</code> function.
        The library doesn't care.
      </p>
    </div>

    <div>
      <p class="text-accent font-mono text-xs mb-1.5">06</p>
      <h3 class="text-base font-semibold text-text-primary mb-1.5 !mt-0">Zero dependencies, ~100 lines of logic</h3>
      <p class="text-text-secondary text-sm leading-relaxed">
        State in a <code>WeakMap</code> (no <code>this</code> pollution).
        Immutability via <code>deepFreeze</code>. Actions via shallow copy.
        No Immer, no DI container, no ORM. The entire entity module fits in a single file.
      </p>
    </div>
  </div>
</section>

<!-- ── USAGE ──────────────────────────────────────────────── -->
<section class="border-y border-border-muted bg-bg-surface/50">
  <div class="max-w-[960px] mx-auto px-6 py-16 sm:py-20">
    <p class="text-text-muted text-xs font-mono uppercase tracking-[0.15em] mb-3">DX</p>
    <h2 class="text-2xl font-semibold mb-3">From declaration to use case</h2>
    <p class="text-text-secondary mb-8 max-w-lg leading-relaxed">
      The entity you declared is now a typed object you use in commands and queries.
      <code>create()</code> validates input. <code>actions</code> mutate through
      defined paths. <code>props</code> and computed properties give you a read
      surface. No surprises.
    </p>

    <div class="bg-bg-code border border-border-default rounded-lg overflow-hidden">
      <div class="flex items-center gap-2 px-4 py-2.5 border-b border-border-muted bg-bg-surface">
        <span class="w-3 h-3 rounded-full bg-red/60"></span>
        <span class="w-3 h-3 rounded-full bg-amber/60"></span>
        <span class="w-3 h-3 rounded-full bg-green/60"></span>
        <span class="ml-3 text-xs text-text-muted font-mono">update-profile.command.ts</span>
      </div>
      <pre class="!border-0 !rounded-none !m-0 !p-5 text-sm language-typescript"><code>{usageCode}</code></pre>
    </div>

    <div class="grid sm:grid-cols-3 gap-4 mt-8 text-sm">
      <div class="bg-bg-overlay/50 border border-border-muted rounded-md p-4">
        <p class="font-semibold text-text-primary mb-1">Typed at every boundary</p>
        <p class="text-text-secondary">
          <code>create()</code> params are typed from schema.
          <code>props</code> fields are typed.
          <code>actions</code> are typed.
          No <code>any</code> anywhere in the call chain.
        </p>
      </div>
      <div class="bg-bg-overlay/50 border border-border-muted rounded-md p-4">
        <p class="font-semibold text-text-primary mb-1">No framework lock-in</p>
        <p class="text-text-secondary">
          Your entities are plain classes. Use them in Express, Fastify, Lambda,
          or a unit test. The library doesn't own your architecture.
        </p>
      </div>
      <div class="bg-bg-overlay/50 border border-border-muted rounded-md p-4">
        <p class="font-semibold text-text-primary mb-1">Trivial to test</p>
        <p class="text-text-secondary">
          <code>UserProfile.create({'{...}'})</code> and call <code>actions</code>.
          No DI to mock, no database to spin up. Assert on <code>props</code>.
        </p>
      </div>
    </div>
  </div>
</section>

<!-- ── INSTALL ────────────────────────────────────────────── -->
<section class="border-t border-border-muted">
  <div class="max-w-[960px] mx-auto px-6 py-16 sm:py-20 text-center">
    <p class="text-text-muted text-xs font-mono uppercase tracking-[0.15em] mb-6">
      You know your domain. The library handles the rest.
    </p>
    <div class="inline-block bg-bg-code border border-border-default rounded-md px-5 py-3 font-mono text-sm mb-4">
      npm install @sotajs/ddd
    </div>
    <div class="text-text-muted text-sm space-x-4">
      <span>TypeScript ^5.0</span>
      <span>&middot;</span>
      <span>Zero dependencies</span>
      <span>&middot;</span>
      <a href="/docs/getting-started/" class="text-accent hover:underline">Read the docs &rarr;</a>
    </div>
  </div>
</section>

</BaseLayout>
